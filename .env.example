# ===========================================
# Absensholat API - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# Application Settings
# ===========================================
# Environment: 'development' or 'production'
ENVIRONMENT=development

# API Server Configuration
API_PORT=8080
API_HOST=localhost:8080

# Swagger Documentation Host (optional)
# Development: localhost:8080
# Production: your-api-domain.com
SWAGGER_HOST=localhost:8080

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/absensi_sholat_db?sslmode=disable

# ===========================================
# Security Configuration (REQUIRED)
# ===========================================
# JWT Secret Key - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars

# ===========================================
# CORS Configuration (Production)
# ===========================================
# Comma-separated list of allowed origins
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# Firebase Configuration (Optional)
# ===========================================
# Path or URL to Firebase credentials JSON
FIREBASE_CREDENTIALS_PATH=

# ===========================================
# Email Configuration (MailerSend)
# ===========================================
# MailerSend API credentials for OTP emails
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=

# ===========================================
# Rate Limiting (Optional)
# ===========================================
# Requests per minute per IP (default: 60)
RATE_LIMIT_RPM=60

# ===========================================
# Logging Configuration
# ===========================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# ===========================================
# Redis Cache Configuration (Optional)
# ===========================================
# Redis connection URL for caching
# Format: redis://user:password@host:port/db
# Leave empty to disable caching
REDIS_URL=
